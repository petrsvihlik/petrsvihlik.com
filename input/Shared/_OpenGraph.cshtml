@using PetrSvihlik.Com.Models.ContentTypes
@model Article
@* Open Graph - https://ogp.me/ *@

@if (Model != null)
{
    <meta property="og:type" content="article" />
    <meta property="og:url" content="@Document.GetLink(true)" />
    @if (!string.IsNullOrWhiteSpace(Model.Title))
    {
        <meta property="og:title" content="@Model.Title" />
    }
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <meta property="og:description" content="@Model.Description" />
    }
    @if (Model.ArticleAuthor != null)
    {
        <meta property="article:author" content="@Model.ArticleAuthor.Name" />
    }
    @if (Model.SelectedCategory != null && !string.IsNullOrWhiteSpace(Model.SelectedCategory.Title))
    {
        <meta property="article:section" content="@Model.SelectedCategory.Title" />
    }
    @foreach (var tag in Model.TagObjects)
    {
        <meta property="article:tag" content="@tag.Title" />
    }
    @if (Model.PublishDate.HasValue)
    {
        <meta property="article:published_time" content="@Model.PublishDate.Value.ToString("o")" />
    }
}
